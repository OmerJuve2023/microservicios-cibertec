      "name": "01. Autenticación",
      "item": [
        {
          "name": "POST Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "GET Validar Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/validate?token={{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "validate"],
              "query": [
                {
                  "key": "token",
                  "value": "{{token}}"
                }
              ]
            }
          }
        }
      ]
    },
